# Pick 환경 변수 템플릿 — `.env` 또는 `.env.local`로 복사한 뒤 본인 값으로 채우세요.

# Gemini API key — Google AI Studio (https://aistudio.google.com/app/apikey)에서 발급.
# Vite는 빌드 타임에 dist 번들로 인라인합니다 → Google AI Studio에서 HTTP referrer 제한 필수.
VITE_GEMINI_API_KEY=

# Firebase Web SDK config — Firebase 콘솔 → 프로젝트 설정 → 일반 → 내 앱 → Web 앱 SDK 구성에서 복사.
# 정책상 secret 아니지만(rules로 보호), fork 사용자는 본인 프로젝트 값으로 변경 필수.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AI 심사 prompt에 추가 주입할 강의 맥락 (선택, 한 줄 권장 — 따옴표로 감싸세요).
# 비워두면 일반화된 기본 prompt 사용. 본인 강의명/대상자/과제 의도 등을 적으면 7판사가 그 맥락에 맞춰 평가합니다.
#
# [점수 가중치 — 가중치를 코드로 매기지 않고 prompt 단에서 7판사 분포를 유도하는 방식]
# 강의의 핵심 평가축을 명시하면 그 축 담당 판사가 더 적극적으로 점수 차별화 + 비중을 둠.
# 7판사 평균은 그대로지만 강조축의 분산이 커져 결과적으로 가중 효과.
#
# 예시 (디자인 강조 강의):
#   VITE_COURSE_CONTEXT="강의: '비개발자를 위한 UI 디자인'. 평가 핵심축은 시각적 완성도(이디자)와 사용자 직관성(박사용). 이 두 축은 점수에 가장 큰 영향을 주고, 그 외 판사는 보조적으로 평가하세요."
#
# 예시 (PM/문제정의 강조):
#   VITE_COURSE_CONTEXT="강의: '바이브코딩 워크숍'. 평가 핵심축은 문제 정의(김기획)와 기능 완성도(한완성). 이 두 축이 가장 중요하고, 다른 판사는 보완 관점."
VITE_COURSE_CONTEXT=

{
  "rules": {
    "admins": {
      ".read": true,
      ".write": true,
      "$uid": {
        ".validate": "newData.hasChild('username') && newData.hasChild('passwordHash')",
        "username": { ".validate": "newData.isString() && newData.val().length >= 2 && newData.val().length <= 20" },
        "passwordHash": { ".validate": "newData.isString()" },
        "displayName": { ".validate": "newData.isString() && newData.val().length <= 20" },
        "role": { ".validate": "newData.isString() && newData.val().matches(/^(master|admin|staff)$/)" },
        "approved": { ".validate": "newData.isBoolean()" },
        "createdAt": { ".validate": true }
      }
    },
    "courseTemplates": {
      ".read": true,
      ".write": true,
      "$courseId": {
        ".validate": "newData.hasChild('name')",
        "name": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "createdAt": { ".validate": true },
        "questions": {
          ".write": true,
          "$qId": {
            ".validate": "newData.hasChild('title') && newData.hasChild('type')",
            "title": { ".validate": "newData.isString() && newData.val().length <= 500" },
            "type": { ".validate": "newData.isString() && newData.val().matches(/^(choice|ox|quiz|wordcloud|qna|scale|debate|ranking|fillinblank|check|mysteryBox|hintQuiz|imageSlide|aiJudge|subjective)$/)" },
            "$other": { ".validate": true }
          }
        }
      }
    },
    "questionLibrary": {
      ".read": true,
      ".write": true,
      "$adminUid": {
        "$qId": {
          ".validate": "newData.hasChild('title') && newData.hasChild('type')",
          "title": { ".validate": "newData.isString() && newData.val().length <= 500" },
          "type": { ".validate": "newData.isString() && newData.val().matches(/^(choice|ox|quiz|wordcloud|qna|scale|debate|ranking|fillinblank|check|mysteryBox|hintQuiz|imageSlide|aiJudge|subjective)$/)" },
          "savedAt": { ".validate": "newData.isNumber()" },
          "updatedAt": { ".validate": "newData.isNumber()" },
          "$other": { ".validate": true }
        }
      }
    },
    "courses": {
      ".read": true,
      ".write": true,
      "$courseId": {
        ".validate": "newData.hasChild('name') && newData.hasChild('ownerId')",
        "name": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "ownerId": { ".validate": "newData.isString()" },
        "ownerName": { ".validate": "newData.isString() && newData.val().length <= 20" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "staff": {
          "$staffUid": {
            ".validate": "newData.hasChild('displayName')",
            "displayName": { ".validate": "newData.isString() && newData.val().length <= 20" },
            "assignedAt": { ".validate": "newData.isNumber()" }
          }
        }
      }
    },

    "staffCourses": {
      ".read": true,
      ".write": true,
      "$staffUid": {
        "$courseId": {
          ".validate": "newData.isBoolean()"
        }
      }
    },

    "sessions": {
      ".read": true,
      "$sessionId": {
        ".write": true,

        "creatorId": {
          ".validate": "newData.isString() && newData.val().length <= 50"
        },
        "courseId": {
          ".validate": "newData.isString() && newData.val().length <= 50"
        },

        "status": {
          ".write": true,
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "currentQuestion": {
          ".write": true,
          ".validate": "newData.isString() || !newData.exists()"
        },
        "persistentAssignmentId": {
          ".write": true,
          ".validate": "newData.isString() || !newData.exists()"
        },
        "currentMode": {
          ".write": true,
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "pendingEvent": {
          ".write": true
        },
        "createdAt": {
          ".write": true
        },
        "courseName": {
          ".write": true,
          ".validate": "newData.isString() && newData.val().length <= 100"
        },
        "roundNumber": {
          ".write": true,
          ".validate": "newData.isNumber()"
        },

        "questions": {
          ".write": true,
          "$questionId": {
            ".validate": "newData.hasChild('title') && newData.hasChild('type')",
            "title": {
              ".validate": "newData.isString() && newData.val().length <= 500"
            },
            "type": {
              ".validate": "newData.isString() && newData.val().matches(/^(choice|ox|quiz|wordcloud|qna|scale|debate|ranking|fillinblank|check|mysteryBox|hintQuiz|imageSlide|aiJudge|subjective)$/)"
            },
            "modelAnswer": {
              ".validate": "newData.isString() && newData.val().length <= 1000"
            },
            "votes": {
              "$participantId": {
                ".validate": "newData.hasChild('value') && !root.child('sessions').child($sessionId).child('questions').child($questionId).child('revealedAt').exists() && (!root.child('sessions').child($sessionId).child('timer').child('endTime').exists() || now < root.child('sessions').child($sessionId).child('timer').child('endTime').val() + 2000)",
                "value": {
                  ".validate": "newData.isString() && newData.val().length <= 500"
                },
                "nickname": {
                  ".validate": "newData.isString() && newData.val().length <= 10"
                }
              }
            },

            "submissions": {
              "$participantId": {
                ".validate": "newData.hasChild('name')",
                "name": { ".validate": "newData.isString() && newData.val().length <= 20" },
                "title": { ".validate": "newData.isString() && newData.val().length <= 200" },
                "description": { ".validate": "newData.isString() && newData.val().length <= 500" },
                "imageUrl": { ".validate": "newData.isString() && newData.val().length <= 2000" },
                "code": { ".validate": "newData.isString() && newData.val().length <= 100000" },
                "submittedAt": { ".validate": true }
              }
            },

            "aiResults": {
              "$participantId": {
                ".validate": "newData.hasChild('summary')",
                "summary": {
                  "avgScore": { ".validate": "newData.isNumber()" },
                  "totalScore": { ".validate": "newData.isNumber()" },
                  "totalJudges": { ".validate": "newData.isNumber()" },
                  "erroredJudges": { ".validate": "newData.isNumber()" },
                  "imageFailed": { ".validate": "newData.isBoolean()" }
                },
                "judges": { ".validate": true },
                "judgedAt": { ".validate": true }
              }
            },

            "aiGrades": {
              "$participantId": {
                ".validate": "newData.hasChild('score')",
                "score": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
                "feedback": { ".validate": "newData.isString() && newData.val().length <= 500" },
                "gradedAt": { ".validate": true }
              }
            },

            "aiTop3": {
              ".validate": true,
              "first":  { ".validate": "newData.hasChild('submissionId')" },
              "second": { ".validate": "newData.hasChild('submissionId')" },
              "third":  { ".validate": "newData.hasChild('submissionId')" }
            },

            "aiJudgeState": {
              ".validate": true,
              "status": { ".validate": "newData.isString() && newData.val().matches(/^(idle|judging|done|aborted|error)$/)" },
              "revealedUpTo": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3" },
              "current": { ".validate": "newData.isNumber()" },
              "total": { ".validate": "newData.isNumber()" },
              "currentName": { ".validate": "newData.isString() && newData.val().length <= 30" },
              "message": { ".validate": "newData.isString() && newData.val().length <= 500" },
              "startedAt": { ".validate": true },
              "completedAt": { ".validate": true }
            },

            "aiJudgeLog": {
              ".validate": true,
              "currentSubmissionId": { ".validate": "newData.isString() && newData.val().length <= 100" },
              "currentName": { ".validate": "newData.isString() && newData.val().length <= 30" },
              "startedAt": { ".validate": true },
              "judges": {
                "$judgeId": {
                  "name": { ".validate": "newData.isString() && newData.val().length <= 20" },
                  "state": { ".validate": "newData.isString() && newData.val().matches(/^(thinking|done|error)$/)" },
                  "hint": { ".validate": "newData.isString() && newData.val().length <= 200" },
                  "score": { ".validate": "newData.isNumber() || !newData.exists()" },
                  "at": { ".validate": "newData.isNumber()" }
                }
              }
            }
          }
        },

        "participants": {
          ".write": true,
          "$participantId": {
            ".validate": "newData.hasChild('nickname')",
            "nickname": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 10"
            }
          }
        },

        "reactions": {
          ".write": true,
          "$reactionId": {
            ".validate": "newData.hasChild('type') && newData.hasChild('timestamp')",
            "type": {
              ".validate": "newData.isString() && newData.val().length <= 20"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            }
          }
        },

        "urgentQuestions": {
          ".write": true,
          "$questionId": {
            ".validate": "newData.hasChild('text') && newData.hasChild('timestamp')",
            "text": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 200"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            },
            "read": {
              ".validate": "newData.isBoolean()"
            },
            "reviewing": {
              ".validate": "newData.isBoolean()"
            }
          }
        },

        "timerEnd": {
          ".write": true,
          ".validate": "newData.isNumber() || !newData.exists()"
        },

        "timerDuration": {
          ".write": true,
          ".validate": "newData.isNumber()"
        },

        "classQuestions": {
          ".write": true,
          "$questionId": {
            ".validate": "newData.hasChild('text') && newData.hasChild('nickname')",
            "text": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 200"
            },
            "nickname": {
              ".validate": "newData.isString() && newData.val().length <= 20"
            },
            "participantId": {
              ".validate": "newData.isString()"
            },
            "timestamp": {
              ".validate": true
            },
            "answered": {
              ".validate": "newData.isBoolean()"
            },
            "upvotes": {
              ".write": true
            },
            "answeredBy": { ".validate": "newData.isString()" },
            "answeredByRole": { ".validate": "newData.isString()" },
            "hidden": { ".validate": "newData.isBoolean()" },
            "answers": {
              ".write": true,
              "$answerId": {
                ".validate": "newData.hasChild('text') && newData.hasChild('nickname')",
                "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 500" },
                "nickname": { ".validate": "newData.isString() && newData.val().length <= 20" },
                "participantId": { ".validate": "newData.isString()" },
                "timestamp": { ".validate": true },
                "role": { ".validate": "newData.isString()" },
                "upvotes": { ".write": true }
              }
            }
          }
        },

        "qaStats": {
          ".read": true,
          ".write": true,
          "$participantId": {
            "nickname": { ".validate": "newData.isString()" },
            "questions": { ".validate": "newData.isNumber()" },
            "answers": { ".validate": "newData.isNumber()" }
          }
        },

        "chatBubbles": {
          ".write": true,
          "$bubbleId": {
            ".validate": "newData.hasChild('text') && newData.hasChild('nickname')",
            "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20" },
            "nickname": { ".validate": "newData.isString() && newData.val().length <= 20" },
            "participantId": { ".validate": "newData.isString()" },
            "timestamp": { ".validate": true }
          }
        },

        "chat": {
          ".write": true,
          "$messageId": {
            ".validate": "newData.hasChild('text') && newData.hasChild('sender')",
            "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 500" },
            "sender": { ".validate": "newData.isString() && newData.val().length <= 20" },
            "senderType": { ".validate": "newData.isString()" },
            "timestamp": { ".validate": true }
          }
        },

        "staffChat": {
          ".write": true,
          "$messageId": {
            ".validate": "newData.hasChild('text') && newData.hasChild('sender')",
            "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 500" },
            "sender": { ".validate": "newData.isString() && newData.val().length <= 20" },
            "senderType": { ".validate": "newData.isString()" },
            "timestamp": { ".validate": true }
          }
        },

        "dmByStudent": {
          ".write": true,
          "$studentId": {
            ".validate": "newData.isString() && newData.val().length <= 100"
          }
        },

        "dm": {
          ".write": true,
          "$dmId": {
            ".validate": "newData.hasChild('studentId') && newData.hasChild('status')",
            "studentId": {
              ".validate": "newData.isString() && (!data.exists() || data.val() === newData.val())"
            },
            "studentName": { ".validate": "newData.isString() && newData.val().length <= 20" },
            "staffId": { ".validate": "newData.isString() || !newData.exists()" },
            "staffName": { ".validate": "newData.isString() || !newData.exists()" },
            "status": { ".validate": "newData.isString() && newData.val().matches(/^(waiting|active|resolved)$/)" },
            "createdAt": {
              ".validate": "!data.exists() || data.val() === newData.val()"
            },
            "messages": {
              "$messageId": {
                ".validate": "newData.hasChild('text') && newData.hasChild('sender') && (!data.exists() || data.child('sender').val() === newData.child('sender').val())",
                "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 500" },
                "sender": { ".validate": "newData.isString() && newData.val().length <= 20" },
                "senderType": {
                  ".validate": "newData.isString() && newData.val().matches(/^(student|staff|instructor|system)$/)"
                },
                "timestamp": { ".validate": true },
                "contextQuestionId": { ".validate": "newData.isString() && newData.val().length <= 100" }
              }
            },
            "typing": {
              "$userId": {
                "name": { ".validate": "newData.isString() && newData.val().length <= 20" },
                "at": { ".validate": "newData.isNumber()" }
              }
            }
          }
        },

        "handRaises": {
          ".write": true
        },

        "speedQuiz": {
          ".write": true,
          ".validate": "!newData.exists() || newData.hasChild('active')"
        },

        "teamBattle": {
          ".write": true,
          ".validate": "!newData.exists() || newData.hasChild('active')"
        },

        "scores": {
          ".write": true,
          "$participantId": {
            ".validate": "newData.hasChild('nickname') && newData.hasChild('total')",
            "nickname": {
              ".validate": "newData.isString() && newData.val().length <= 10"
            },
            "total": {
              ".validate": "newData.isNumber()"
            },
            "tickets": {
              ".validate": "newData.isNumber()"
            }
          }
        },

        "gameResult": {
          ".write": true,
          ".validate": "newData.hasChild('mode') && newData.hasChild('winners') && newData.hasChild('resultId')",
          "mode": { ".validate": "newData.isString() && newData.val().length <= 20" },
          "winners": { ".validate": true },
          "resultId": { ".validate": "newData.isString() && newData.val().length <= 50" },
          "timestamp": { ".validate": "newData.isNumber()" },
          "allParticipantIds": { ".validate": true }
        },

        "$other": {
          ".write": true
        }
      }
    },

    "assignments": {
      ".read": true,
      "$assignmentId": {
        ".write": true,
        "submissions": {
          "$submissionId": {
            ".read": true,
            ".write": true,
            ".validate": "newData.hasChild('name')",
            "name": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30 && (!data.exists() || data.child('name').val() === newData.child('name').val())"
            },
            "pin": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 8 && (!data.exists() || !data.child('pin').exists() || data.child('pin').val() === newData.child('pin').val()))"
            },
            "prdContent": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 10000)"
            },
            "code": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100000)"
            },
            "screenshots": { ".validate": true },
            "submittedAt": { ".validate": true },
            "updatedAt": { ".validate": "!newData.exists() || newData.isNumber()" }
          }
        },
        "results": {
          "$submissionId": {
            ".read": true,
            ".write": true,
            "summary": { ".validate": true },
            "judges": { ".validate": true },
            "judgedAt": { ".validate": true }
          }
        },
        "awards": {
          ".read": true,
          ".write": true
        }
      }
    }
  }
}
